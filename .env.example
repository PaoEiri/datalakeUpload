# Copy this file to .env and update values for your environment.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_SECURE=false

# Buckets
MLFLOW_ARTIFACT_BUCKET=mlflow-artifacts
DATASETS_BUCKET=datasets

# Service endpoints
MINIO_ENDPOINT=http://${MINIO_HOST}:${MINIO_PORT}
MLFLOW_TRACKING_URI=http://${MLFLOW_HOST}:${MLFLOW_SERVER_PORT}
PREFECT_API_URL=http://${PREFECT_API_HOST}:${PREFECT_API_PORT}/api

# Services
DATASET_API_PORT=8000
MLFLOW_HOST=mlflow
MLFLOW_SERVER_PORT=5000
PREFECT_API_HOST=prefect-server
PREFECT_API_PORT=4200
