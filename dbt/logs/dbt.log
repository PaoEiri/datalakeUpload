  create  table "postgres"."core"."dim_tiempo__dbt_tmp"
  
  
    as
  
  (
    

SELECT
    ROW_NUMBER() OVER (ORDER BY fecha, trimestre) AS id_tiempo,
    fecha,
    anio,
    trimestre,
    CASE
        WHEN trimestre IS NULL THEN CAST(anio AS VARCHAR)
        ELSE CONCAT('T', trimestre, ' ', anio)
    END AS label_periodo,
    CASE trimestre
        WHEN 1 THEN 'Enero - Marzo'
        WHEN 2 THEN 'Abril - Junio'
        WHEN 3 THEN 'Julio - Septiembre'
        WHEN 4 THEN 'Octubre - Diciembre'
        ELSE 'Año completo'
    END AS descripcion_trimestre
FROM (
    SELECT DISTINCT anio, trimestre, fecha
    FROM "postgres"."intermediate"."int_precios_vivienda_unificado"
    WHERE fecha IS NOT NULL

    UNION

    SELECT DISTINCT
        anio,
        trimestre,
        MAKE_DATE(anio, CASE trimestre WHEN 1 THEN 1 WHEN 2 THEN 4 WHEN 3 THEN 7 WHEN 4 THEN 10 END, 1) AS fecha
    FROM "postgres"."intermediate"."int_transacciones_unificado"
    WHERE anio IS NOT NULL AND trimestre IS NOT NULL

    UNION

    SELECT DISTINCT anio, CAST(NULL AS SMALLINT) AS trimestre, MAKE_DATE(anio, 1, 1) AS fecha
    FROM "postgres"."staging"."stg_indicadores_ine"
    WHERE anio IS NOT NULL
) t
ORDER BY fecha, trimestre
  );
  
