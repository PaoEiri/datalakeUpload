LEFT JOIN "postgres"."public_core"."dim_tiempo"        dt  ON stg.fecha       = dt.fecha
LEFT JOIN "postgres"."public_core"."dim_indicador"     di  ON stg.indicador   = di.nombre_indicador
LEFT JOIN "postgres"."public_core"."dim_tipo_vivienda" dtv ON stg.tipo_vivienda = dtv.nombre_tipo
  );
  
